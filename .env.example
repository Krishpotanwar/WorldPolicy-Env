HF_TOKEN=your_huggingface_token
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=your_model_name
MODEL_NAME_FALLBACK=your_fallback_model_name
ENV_URL=http://127.0.0.1:7860
# Optional: mappo | groq | auto (default in code is mappo)
WP_DEBATE_BACKEND=mappo
# Optional, only needed when WP_DEBATE_BACKEND=groq (or auto fallback)
GROQ_API_KEY=
